# ===== AuditAgentX 环境变量示例 =====
# 复制本文件为 .env 并填入真实配置

# ---- 大模型配置（OpenAI 兼容接口）----
# 支持 OpenAI / DeepSeek / Qwen(通义) / 本地 vLLM 等
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://api.example.com/v1
LLM_MODEL=your-model-name
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096
# 请求超时（秒）
LLM_TIMEOUT=120

# ---- 数据库 ----
# SQLite（默认，开箱即用）
DATABASE_URL=sqlite:///./data/auditagentx.db
# PostgreSQL 示例：
# DATABASE_URL=postgresql+psycopg2://user:pass@localhost:5432/auditagentx

# ---- 数据与工作目录 ----
DATA_DIR=./data
WORKSPACE_DIR=./data/projects

# ---- 静态扫描工具开关（需在系统或 Docker 中预装）----
ENABLE_SEMGREP=true
ENABLE_BANDIT=true
ENABLE_GITLEAKS=true
ENABLE_TRIVY=false

# ---- 沙箱验证 ----
ENABLE_SANDBOX=false
DOCKER_HOST=unix:///var/run/docker.sock
SANDBOX_TIMEOUT=60

# ---- 服务 ----
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
