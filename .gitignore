# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/
env/

# Environment and secrets
.env
.env.*
!.env.example

# Databases and runtime data
*.db
*.sqlite
*.sqlite3
data/projects/*
data/scans/*
data/reports/*
data/sandbox/*
data/uploads/*
data/*.log
!data/**/.gitkeep

# Frontend
frontend/node_modules/
frontend/dist/
frontend/tsconfig.tsbuildinfo

# IDE and OS files
.vscode/
.idea/
.DS_Store

# Local Claude Code config / agent memory
.claude/

# Temporary scan outputs
*.sarif
tmp/

# Runtime logs
logs/
*.log

# Tokens / keys / proxy configs（除 .env 外的敏感文件，绝不提交）
*_token
*.token
*.pem
*.key
.netrc
.npmrc
proxychains.conf
proxy.conf

# Docker / harness 运行时产物
docker/**/*.log
*harness*.tmp

# 说明：顶层 reports/ 为有意提交的实验产物（已被 git 跟踪），此处不做 blanket ignore
# 以免与已跟踪文件冲突；镜像层面由 .dockerignore 排除 reports/。若今后希望新的
# 运行时报告不进版本库，再按需在此追加具体子目录规则。
